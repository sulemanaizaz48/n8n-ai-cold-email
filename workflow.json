          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rawText = $json.content.parts[0].text;\n\n// Convert escaped newlines\nconst cleaned = rawText.replace(/\\\\n/g, '\\n');\n\n// Extract subject\nconst subjectMatch = cleaned.match(/Subject:\\s*(.*)/i);\n\nconst subject = subjectMatch\n  ? subjectMatch[1].trim()\n  : \"No Subject\";\n\n// Remove subject line from body\nconst body = cleaned\n  .replace(/Subject:\\s*.*/i, '')\n  .trim();\n\nreturn {\n  subject,\n  body\n};"
      },
